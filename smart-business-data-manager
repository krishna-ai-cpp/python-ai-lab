        if ask == "1":
          val = input("enter the constant value: ")
          f[col].fillna(val,inplace = True)
          print(f)
        elif ask == "2":
          f[col].fillna(f[col].mean(),inplace = True)
          print(f)
        elif ask == "3":
          f[col].fillna(f[col].median(),inplace = True)
          print(f)
        elif ask == "4":
          f[col].fillna(f[col].mode(),inplace = True)
          print(f)
        elif ask == "5":
          f[col] = f[col].ffill()
          print(f)
        elif ask == "6":
          f[col] = f[col].bfill()
          print(f)
        else:
          pass
