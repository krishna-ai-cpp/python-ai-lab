      print(f"{e}")
    res = input("DO YOU WANT TO RENAME A COLOUMN HEADER (YES/NO): ")
    try:
      if res.lower() == "yes":
        old = input("enter the old header name: ")
        new = input("enter the new header name: ")
        f.rename(columns = {old:new},inplace = True)
        print(f)
      else:
        pass
