          f[new] = f[col1] * f[col2]
          print(f[new])
        elif ar == "4":
          f[new] = f[col1] / f[col2]
          print(f[new])
        elif ar == "5":
          f[new] = (f[col1] + f[col2]) / 2
          print(f[new])
